{
  "expo": {
    "name": "AGRINOVA",
    "slug": "agrinova",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/appi.png",
    "userInterfaceStyle": "light",
    "scheme": "kukumart",
    "splash": {
      "backgroundColor": "#154212",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kukumart.app"
    },
    "android": {
      "adaptiveIcon": {
      "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.kukumart.app",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AGRINOVA to access your photos to upload product images.",
          "cameraPermission": "Allow AGRINOVA to access your camera to take product photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AGRINOVA to use your location to deliver orders to your address.",
          "locationWhenInUsePermission": "Allow AGRINOVA to use your location to set your delivery address."
        }
      ],
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "process.env.GOOGLE_MAPS_API_KEY"
        }
      ]
    ]
  }
}
